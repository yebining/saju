# Gemini 풀이 호출용. 없으면 결정론적 더미 풀이로 동작.
# 발급(무료): https://aistudio.google.com/apikey  → Vercel 환경변수에도 동일 키 등록.
GEMINI_API_KEY=...

# (선택) 풀이 영구 저장용 Supabase. 없으면 저장만 비활성(앱은 동작).
# https://supabase.com → 프로젝트 → Settings → API. 서버 전용(클라이언트 노출 금지).
# 테이블은 docs/supabase-schema.sql 을 Supabase SQL Editor에서 실행해 생성.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
